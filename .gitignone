                autosize: true,
                scene: { camera: { eye: { x: 1.5, y: 1.5, z: 1.5 } } }
            };

            // 描画を実行（すでにある場合は更新される）
            Plotly.newPlot('graph', data, layout);
        }

        // スライダーが動いたら再描画するイベントリスナー
        document.getElementById('paramA').addEventListener('input', drawGraph);

        // 初期描画
