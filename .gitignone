    <script>
        // グラフを描画する関数
        function drawGraph() {
            const a = parseFloat(document.getElementById('paramA').value);
            document.getElementById('valA').innerText = a;

            // 陽的スキームなどで計算した3Dデータ（X, Y, Z）をここで生成
            let xData = [], yData = [], zData = [];
